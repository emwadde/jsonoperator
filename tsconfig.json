{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": ".",
    "types": ["node"]
  },
  "include": ["*.js"],
  "exclude": ["node_modules"]
}